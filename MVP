def extract_color_hog(img_list):
    hog_features = []
    for img in img_list:
        img_rgb = cv2.cvtColor(img, cv2.COLOR_BGR2RGB)
        
        fd = hog(
            img_rgb,
            orientations=9,
            pixels_per_cell=(8, 8),
            cells_per_block=(2, 2),
            visualize=False,
            channel_axis=-1 
        )
        hog_features.append(fd)
    return np.array(hog_features)

