def predict_new_image_with_metadata(image_path, age, sex, localization):
    img = cv2.imread(image_path)
    if img is None:
        raise ValueError(f"No s'ha pogut carregar la imatge a: {image_path}")

    img_resized = cv2.resize(img, (64, 64))
    img_rgb = cv2.cvtColor(img_resized, cv2.COLOR_BGR2RGB)

    features = hog(
        img_rgb,
        orientations=9,
        pixels_per_cell=(8, 8),
        cells_per_block=(2, 2),
        feature_vector=True,
        channel_axis=-1 
    )

    new_metadata = pd.DataFrame([{
        "age": age,
        "sex": sex,
        "localization": localization
    }])

    new_metadata_encoded = pd.get_dummies(new_metadata, columns=["sex", "localization"])
    
    new_metadata_encoded = new_metadata_encoded.reindex(
        columns=metadata_all_encoded.columns, 
        fill_value=0
    )

    combined_features = np.concatenate(
        [features.reshape(1, -1), new_metadata_encoded.values], 
        axis=1
    )

    prob_cancer = rf_hog_metadata.predict_proba(combined_features)[0][0]
    
    threshold = 0.165
    prediction = "cancerous" if prob_cancer >= threshold else "non_cancerous"

    plt.figure(figsize=(5, 5))
    plt.imshow(cv2.cvtColor(img, cv2.COLOR_BGR2RGB))
    color_text = 'red' if prediction == "cancerous" else 'green'
    plt.title(f"Predicció: {prediction}\nProbabilitat: {prob_cancer:.2%}", color=color_text, fontsize=14)
    plt.axis("off")
    plt.show()

    return prediction, prob_cancer

